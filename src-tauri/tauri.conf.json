{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Billar tres bandas",
  "version": "1.0.1",
  "identifier": "com.jjarango.premiumplus",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../app"
  },
  "app": {
    "windows": [
      {
        "title": "Billar tres bandas | Juan José Arango E.",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}